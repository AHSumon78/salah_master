<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_glass_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
         <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌙 25 Dhul Hijjah 1447"
            android:textColor="#34D399"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="start"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3" android:orientation="vertical"
            android:gravity="center">

            <TextClock
                android:id="@+id/widget_gregorian_date_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="📅 dd MMM"
                android:format24Hour="📅 dd MMM"
                android:timeZone="Asia/Dhaka"
                android:textColor="#34D399"
                android:textSize="14sp"
                android:textStyle="normal"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <TextClock
                android:id="@+id/widget_gregorian_time_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:layout_marginBottom="-4dp" 
                android:format12Hour="hh:mm:ss"
                android:format24Hour="HH:mm:ss"
                android:timeZone="Asia/Dhaka"
                android:textColor="#34D399"
                android:textSize="24sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <TextClock
                android:id="@+id/widget_gregorian_ampm_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="a"
                android:format24Hour="" 
                android:timeZone="Asia/Dhaka"
                android:textColor="#34D399"
                android:textSize="10sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_event_days"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏱️ New Year: 5 Days"
            android:textColor="#34D399"
            android:textSize="14sp"
            android:textStyle="bold" 
            android:gravity="end" android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_sunrise_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:text="@string/widget_sunrise_label"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />

        <TextView
            android:id="@+id/widget_title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asr"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />

        <TextView
            android:id="@+id/tv_sunset_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="12sp"
            android:text="@string/widget_sunset_label"
            android:textColor="#ffffff"
            android:textStyle="bold" 
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/widget_sunrise"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌅 05:12 AM"
            android:textColor="#ffffff"
            android:textSize="13sp" 
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Chronometer
                android:id="@+id/prayer_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01:24:15"
                android:textColor="#34D399"
                android:textSize="24sp"
                android:textStyle="bold" 
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"/>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_sunset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="🌇 06:48 PM"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />
    </LinearLayout>

</LinearLayout>